# ——— Server: RPC (Helius: get key at helius.dev) ———
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# ——— Database ———
DATABASE_URL=file:./dev.db

# ——— Auth ———
NEXTAUTH_SECRET=generate-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ——— Telegram DM replies (webhook). For local dev use ngrok URL here ———
TELEGRAM_WEBHOOK_BASE=

# ——— Platform billing ($10 USDC/month per agent) ———
# Token mint for the platform’s tokenized agent (receives subscription payments)
PLATFORM_AGENT_MINT=

# ——— Credential encryption (for Twitter/Telegram/Discord keys) ———
CREDENTIAL_SECRET=generate-another-long-random-string-32-chars-min

# ——— Twitter / X: credentials are entered per agent in the dashboard (Customize → Twitter app Consumer Key + Secret). No env vars required. ———

# ——— Agent runtime (worker) ———
Z_AI_API_KEY=
AGENT_RUN_INTERVAL_MS=300000
AGENT_MARKET_CAP_INTERVAL_MS=120000

# ——— Worker (optional) ———
REDIS_URL=redis://localhost:6379

# ——— Dev only: skip $10 subscription, allow sign-in without wallet ———
BYPASS_PAYMENT=true
NEXT_PUBLIC_BYPASS_PAYMENT=true
